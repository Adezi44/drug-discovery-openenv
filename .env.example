# --- LLM CONFIGURATION ---
# The endpoint for model inference (Defaults to Hugging Face Router)
API_BASE_URL=https://router.huggingface.co/v1
# The model identifier to use
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
# Your API Key (Hugging Face Token or OpenAI Key)
# NOTE: Use 'Write' permission for HF_TOKEN if you plan to use deploy_hf.py
HF_TOKEN=your_huggingface_token_here
OPENAI_API_KEY=
# --- ENVIRONMENT CONFIGURATION ---
# The URL where the FastAPI server is running
ENV_URL=http://localhost:7860
# Benchmark label for logs
BENCHMARK=drug-discovery

# --- RUNTIME LIMITS ---
# Total time allowed for the entire agent run (in seconds)
TOTAL_RUN_TIMEOUT_SECS=1140
# Max steps per task before giving up
MAX_STEPS_PER_TASK=120
